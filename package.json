{
  "name": "opensage",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "bin": {
    "opensage": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "clean": "rimraf dist",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm build",
    "postbuild": "chmod +x dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alcanivorax/opensage.git"
  },
  "keywords": [
    "cli"
  ],
  "author": "alcanivorax",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/react": "^18.3.28",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "ink": "^4.4.1",
    "ink-text-input": "^6.0.0",
    "openai": "^6.32.0",
    "ora": "^9.3.0",
    "react": "^18.3.1"
  }
}
